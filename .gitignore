# ============================================================
# AI Legal Assistant - Root .gitignore
# ============================================================

# ----- Environment & Secrets -----
.env
.env.*
!.env.example

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ----- Virtual Environments -----
myworld/
venv/
env/
.venv/
ENV/

# ----- Databases -----
*.sqlite3
*.db

# ----- Django -----
/staticfiles/
/mediafiles/
*.log
local_settings.py

# ----- Node / Frontend -----
node_modules/
dist/
dist-ssr/
*.local

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- OS Files -----
.DS_Store
Thumbs.db

# ----- IDE -----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Misc -----
*.pyre_configuration
